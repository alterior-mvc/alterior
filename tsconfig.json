{
	"compilerOptions": {
		"experimentalDecorators": true,
		"target": "es2016",
		"sourceMap": true,
        "strict": true,
		"declarationMap": true,
        "rootDir": "./src",
		"outDir": "./dist",
		"module": "node16",
		"moduleResolution": "node16",
        "stripInternal": true,
		"preserveSymlinks": true,
        "importHelpers": true,
        "esModuleInterop": true,
		"lib": [
			"es2022",
			"dom"
		],
        "types": [ "*" ],
		"declaration": true,
		"emitDecoratorMetadata": true
	},
	"exclude": [
		"node_modules",
		"dist"
	]
}